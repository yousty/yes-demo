#!/bin/sh
set -e

# Wait for Postgres to be ready.
if [ -n "$POSTGRES_HOST" ]; then
  until pg_isready -h "$POSTGRES_HOST" -U "${POSTGRES_USER:-postgres}" >/dev/null 2>&1; do
    echo "Waiting for postgres at $POSTGRES_HOST..."
    sleep 1
  done
fi

# Create + migrate application and eventstore databases.
if [ "${RUN_MIGRATIONS:-true}" = "true" ]; then
  bundle exec rails db:prepare
  bundle exec rake pg_eventstore:create || true
  bundle exec rake pg_eventstore:migrate
fi

exec "$@"
